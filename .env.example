# ===========================================
# Server Environment Variables
# ===========================================

# MongoDB connection string (local for dev, Atlas for production)
MONGODB_URI=mongodb://localhost:27017/placement-feed

# Secret used to sign JWT tokens — use a long random string
JWT_SECRET=your-jwt-secret-here

# Admin credentials — the server auto-creates this admin on startup
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Secret for signed cookies
COOKIE_SECRET=your-cookie-secret-here

# Set to "production" on Render
NODE_ENV=development

# Frontend URL — used for CORS origin and CSRF checks
# On Render, set this to your Vercel deployment URL (e.g. https://theplacementfeed.vercel.app)
CLIENT_URL=http://localhost:5173

# Port the server listens on (Render sets this automatically)
PORT=5000
